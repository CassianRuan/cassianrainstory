    {
      "id": "investigation", "type": "object-hunt", "title": "关键线索", "nextNodeId": "confrontation",
      "scene": "/stories/pause-in-the-rain/images/scene-04-investigation.jpg", "music": "confrontation", "ambience": "fireplace", "enterSfx": [], "transition": "fade",
      "intro": "在房间中找出 4 件关键证物。每一次误判，都可能让真相溜走。",
      "rules": { "timeLimitSec": 60, "maxMistakes": 3 },
      "regions": [
        { "id": "clock", "x": 0.07, "y": 0.49, "width": 0.12, "height": 0.215, "label": "老式闹钟", "feedback": "闹钟停在七点零五分。但根据尸斑，死亡时间至少在九点之后。时间被伪造了。" },
        { "id": "teapot", "x": 0.29, "y": 0.5, "width": 0.105, "height": 0.17, "label": "温热的茶壶", "feedback": "茶壶还有余温。凶手杀人后，仍在这里停留了很久。" },
        { "id": "bow", "x": 0.545, "y": 0.22, "width": 0.12, "height": 0.36, "label": "装饰弓箭", "feedback": "弓弦上有新鲜松香。这不是装饰品，它最近刚被极力拉满。" },
        { "id": "score", "x": 0.69, "y": 0.45, "width": 0.16, "height": 0.21, "label": "残缺乐谱", "feedback": "终章乐谱被撕走了。凶手真正寻找的，是乐谱里的秘密。" }
      ]
    },
    {
      "id": "confrontation", "type": "narrative", "title": "对峙", "nextNodeId": "piano-qte",
      "scene": "/stories/pause-in-the-rain/images/scene-05-confrontation.jpg", "music": "confrontation", "ambience": "rain", "enterSfx": [], "transition": "push",
      "lines": [
        { "character": "evan", "text": "别白费力气了，里斯探长。阿尔伯特的儿子欠了一屁股债，肯定是他为了遗产杀了父亲。", "pauseAfterMs": 450 },
        { "character": "evan", "text": "我只是个路过的猎户，根本不懂你们城里人的把戏。", "pauseAfterMs": 550 },
        { "character": "rees", "text": "你确实是猎户，埃文。但你也是阿尔伯特十年前最得意的学生。直到拉弓废掉你的右手，你再也无法弹琴。", "pauseAfterMs": 550 },
        { "character": "narrator", "text": "埃文的脸色变了。他戴着手套的右手，下意识地缩向身后。", "pauseAfterMs": 450 },
        { "character": "rees", "text": "你用冰块卡住闹钟，伪造七点的死亡时间。然后用弓弦，从背后勒死了毫无防备的老人。", "pauseAfterMs": 500 },
        { "character": "rees", "text": "你留下来喝茶，是为了破解阿尔伯特藏在绝笔乐谱中的暗格密码。", "pauseAfterMs": 650 }
      ]
    },
