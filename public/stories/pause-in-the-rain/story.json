  "nodes": [
    {
      "id": "office-call", "type": "narrative", "title": "深夜值守", "nextNodeId": "office-phone",
      "scene": "/stories/pause-in-the-rain/images/prologue/office-01-working.jpg", "ambience": "rain", "enterSfx": [], "transition": "flash",
      "lines": [
        { "character": "narrator", "text": "夜色压在里斯探长的办公室外。暴雨猛烈敲击着窗户，昏暗房间里，只有一盏台灯还亮着。", "pauseAfterMs": 650 }
      ]
    },
    {
      "id": "office-phone", "type": "narrative", "title": "午夜来电", "nextNodeId": "office-departure",
      "scene": "/stories/pause-in-the-rain/images/prologue/office-02-phone-call.jpg", "ambience": "rain", "enterSfx": ["phone-ring"], "transition": "push",
      "lines": [
        { "character": "narrator", "text": "突兀而尖锐的电话铃声猛然响起。里斯伸手抓起听筒。", "pauseAfterMs": 350 },
        { "character": "rees", "text": "我是里斯。", "pauseAfterMs": 300, "sfx": "phone-pickup" },
        { "character": "narrator", "text": "接线员的声音从听筒里传来：里斯探长，紧急情况。十五分钟前有人报案，著名音乐家在旧城区排练厅被杀。局长要求你立刻赶到现场。", "pauseAfterMs": 500 },
        { "character": "rees", "text": "明白，我这就过去。", "pauseAfterMs": 350 }
      ]
    },
    {
      "id": "office-departure", "type": "narrative", "title": "奔赴现场", "nextNodeId": "road-departure",
      "scene": "/stories/pause-in-the-rain/images/prologue/office-03-grab-keys.jpg", "ambience": "rain", "enterSfx": [], "transition": "push",
      "lines": [
        { "character": "narrator", "text": "里斯挂断电话。", "pauseAfterMs": 280, "sfx": "phone-hangup" },
        { "character": "narrator", "text": "他抓起桌上的车钥匙和风衣，快步走向门口。", "pauseAfterMs": 450, "sfx": "keys-grab" },
        { "character": "narrator", "text": "办公室的门在身后重重关上，他冲入暴雨。", "pauseAfterMs": 650, "sfx": "office-door" }
      ]
    },
    {
      "id": "road-departure", "type": "narrative", "title": "雨夜公路", "nextNodeId": "night-drive",
      "scene": "/stories/pause-in-the-rain/images/prologue/carRun.mp4", "sceneLoop": false, "ambience": "rain", "enterSfx": [], "loopSfx": [], "transition": "flash",
      "lines": [
        { "character": "narrator", "text": "黑色轿车的引擎轰然启动。里斯驶上通往旧城区的荒郊公路，雨刮器在挡风玻璃前疯狂摆动。", "pauseAfterMs": 650 },
        { "character": "narrator", "text": "车灯撕开雨幕，前方不断滚落的碎石和倒木迫使他紧握方向盘。", "pauseAfterMs": 700 }
      ]
    },
    {
