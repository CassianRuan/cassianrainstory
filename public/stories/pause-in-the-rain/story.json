    {
      "id": "bridge-stop", "type": "narrative", "title": "紧急刹车", "nextNodeId": "bridge-quiz",
      "scene": "/stories/pause-in-the-rain/images/prologue/carStop.mp4", "sceneLoop": false, "ambience": "rain", "enterSfx": [], "loopSfx": ["flood-loop"], "transition": "flash",
      "lines": [
        { "character": "narrator", "text": "刺耳的刹车声划破雨夜。黑色轿车猛地停在圣马丁石桥前。该死！桥断了……我要怎样过河？里斯怒吼道", "pauseAfterMs": 650 }
      ]
    },
    {
      "id": "bridge-quiz", "type": "quiz", "title": "应急桥梁验证", "nextNodeId": "bridge-rising",
      "scene": "/stories/pause-in-the-rain/images/prologue/bridge-02-broken-bridge.jpg", "ambience": "rain", "enterSfx": ["terminal-activate"], "loopSfx": ["flood-loop"], "transition": "blackout",
      "intro": "雨幕中，一台老旧的应急桥控制器亮起。只有解开校验题，机械桥才会启动。",
      "question": "观察九宫格中桥墩与水流闸门的变化规律，从 A、B、C、D 中选择缺失图形。",
      "questionImage": "/stories/pause-in-the-rain/images/bridge-quiz-question.jpg",
      "options": [
        { "id": "a", "text": "A" }, { "id": "b", "text": "B" }, { "id": "c", "text": "C" }, { "id": "d", "text": "D" }
      ],
      "correctOptionId": "d", "wrongMessage": "答案不符合桥墩与闸门的变化规律，机械桥拒绝启动。", "successMessage": "验证通过。应急机械桥正在升起……"
    },
    {
      "id": "bridge-rising", "type": "narrative", "title": "机械桥升起", "nextNodeId": "bridge-crossing",
      "scene": "/stories/pause-in-the-rain/images/prologue/bridge-03-mechanical-rise.jpg", "ambience": "rain", "enterSfx": ["bridge-rise"], "loopSfx": ["flood-loop"], "transition": "flash",
      "lines": [
        { "character": "rees", "text": "该死，我当警察可不是为了来算数学题的。", "pauseAfterMs": 450 },
        { "character": "narrator", "text": "车窗外响起沉重的轰鸣。一座临时应急机械桥从断桥下方升起，严丝合缝地连接两岸。", "pauseAfterMs": 800, "sfx": "bridge-lock" }
      ]
    },
    {
      "id": "bridge-crossing", "type": "narrative", "title": "冲过断桥", "nextNodeId": "arrival",
      "scene": "/stories/pause-in-the-rain/images/prologue/bridge-04-car-crossing.jpg", "ambience": "rain", "enterSfx": ["car-accelerate"], "loopSfx": ["flood-loop"], "transition": "push",
      "lines": [
        { "character": "narrator", "text": "里斯猛踩油门。黑色轿车化作一道闪电，冲过桥梁，消失在旧城区的暴雨迷雾中。", "pauseAfterMs": 850, "sfx": "car-pass" }
      ]
    },
    {
      "id": "arrival", "type": "narrative", "title": "暴雨来客", "nextNodeId": "crime-scene",
      "scene": "/stories/pause-in-the-rain/images/scene-01-cabin-exterior.mp4", "music": "investigation", "ambience": "rain", "enterSfx": ["thunder-strike"], "transition": "flash",
      "lines": [
        { "character": "narrator", "text": "暴雨倾盆。闪电划过林间，惨白的光，短暂照亮了那座孤零零的木屋。", "pauseAfterMs": 650 },
        { "character": "narrator", "text": "雨水沿着窗玻璃蜿蜒而下。屋里只有一盏昏黄吊灯，在黑暗中缓慢摇晃。", "pauseAfterMs": 600 }
      ]
    },
    {
      "id": "crime-scene", "type": "narrative", "title": "死亡现场", "nextNodeId": "rees-enters",
      "scene": "/stories/pause-in-the-rain/images/manDead.mp4", "music": "investigation", "ambience": "rain", "enterSfx": [], "transition": "push",
      "lines": [
        { "character": "narrator", "text": "房间中央，钢琴家阿尔伯特低着头坐在扶手椅上，双手垂落，再也不会碰触琴键。", "pauseAfterMs": 650 },
        { "character": "narrator", "text": "一只花斑猫蜷缩在他的脚边。规律的呼噜声，在死寂中显得格外清晰。", "pauseAfterMs": 550 }
      ]
    },
    {
      "id": "rees-enters", "type": "narrative", "title": "侦探入场", "nextNodeId": "spot-difference",
      "scene": "/stories/pause-in-the-rain/images/scene-03-rees-enters.png", "music": "confrontation", "ambience": "rain", "enterSfx": ["door", "footsteps"], "transition": "fade",
      "lines": [
        { "character": "narrator", "text": "门被猛地推开。里斯探长走进木屋，湿透的风衣滴着水，皮鞋在木地板上留下沉重的印迹。", "pauseAfterMs": 500 },
        { "character": "rees", "text": "有人动过这里。暴雨冲不掉房间里的谎言。", "pauseAfterMs": 700 }
      ]
    },
    {
